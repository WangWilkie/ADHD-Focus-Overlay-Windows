<Window x:Class="AdhdFocusOverlay.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Title="FocusFrame 设置"
        Width="430"
        WindowStartupLocation="CenterScreen">
  <Border Padding="20">
    <StackPanel>
      <TextBlock FontSize="18" FontWeight="SemiBold" Text="FocusFrame" />
      <TextBlock Margin="0,6,0,18"
                 Foreground="#666666"
                 Text="调整遮罩外观、快捷键和开机自启。" />

      <TextBlock FontWeight="SemiBold" Text="遮罩预览" />
      <Border x:Name="PreviewSwatch"
              Height="42"
              Margin="0,8,0,16"
              BorderBrush="#22000000"
              BorderThickness="1"
              CornerRadius="8" />

      <TextBlock FontWeight="SemiBold" Text="红色" />
      <Slider x:Name="RedSlider" Margin="0,6,0,12" Maximum="255" ValueChanged="ColorSlider_ValueChanged" />
      <TextBlock FontWeight="SemiBold" Text="绿色" />
      <Slider x:Name="GreenSlider" Margin="0,6,0,12" Maximum="255" ValueChanged="ColorSlider_ValueChanged" />
      <TextBlock FontWeight="SemiBold" Text="蓝色" />
      <Slider x:Name="BlueSlider" Margin="0,6,0,12" Maximum="255" ValueChanged="ColorSlider_ValueChanged" />

      <DockPanel Margin="0,4,0,6">
        <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="透明度" />
        <TextBlock x:Name="OpacityValueText" HorizontalAlignment="Right" />
      </DockPanel>
      <Slider x:Name="OpacitySlider"
              Margin="0,0,0,12"
              Maximum="235"
              Minimum="25"
              ValueChanged="OpacitySlider_ValueChanged" />

      <CheckBox x:Name="DesaturationCheckBox"
                Margin="0,0,0,12"
                Content="保存去饱和偏好设置（后续捕获渲染预留）"
                Checked="SettingsControl_Changed"
                Unchecked="SettingsControl_Changed" />

      <TextBlock FontWeight="SemiBold" Text="切换屏幕快捷键" />
      <TextBlock Margin="0,6,0,6"
                 Foreground="#666666"
                 Text="点击输入框后，直接按下新的切换屏幕快捷键组合。" />
      <TextBox x:Name="SwitchMonitorHotkeyTextBox"
               Margin="0,0,0,12"
               IsReadOnly="True"
               PreviewKeyDown="SwitchMonitorHotkeyTextBox_PreviewKeyDown" />

      <TextBlock FontWeight="SemiBold" Text="隐藏/恢复遮罩快捷键" />
      <TextBlock Margin="0,6,0,6"
                 Foreground="#666666"
                 Text="点击输入框后，直接按下新的隐藏/恢复遮罩快捷键组合。" />
      <TextBox x:Name="ToggleOverlayHotkeyTextBox"
               Margin="0,0,0,8"
               IsReadOnly="True"
               PreviewKeyDown="ToggleOverlayHotkeyTextBox_PreviewKeyDown" />

      <TextBlock x:Name="HotkeyStatusText"
                 Margin="0,0,0,12"
                 Foreground="#666666"
                 Text="快捷键状态正常。" />

      <CheckBox x:Name="StartupCheckBox"
                Margin="0,0,0,16"
                Checked="StartupCheckBox_OnChanged"
                Content="登录 Windows 后自动启动"
                Unchecked="StartupCheckBox_OnChanged" />

      <DockPanel LastChildFill="False">
        <Button Margin="0,0,10,0" Padding="14,8" Click="ResetFocusButton_Click" Content="重置聚焦区域" />
        <Button Padding="18,8" Click="CloseButton_Click" Content="关闭" />
      </DockPanel>
    </StackPanel>
  </Border>
</Window>
