<Window x:Class="AdhdFocusOverlay.Views.InteractionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        WindowStyle="None">
  <Window.Resources>
    <Style x:Key="ResizeThumbStyle" TargetType="{x:Type primitives:Thumb}">
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type primitives:Thumb}">
            <Border Background="#01000000" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Background="{x:Null}" SnapsToDevicePixels="True">
    <Grid.RowDefinitions>
      <RowDefinition Height="18" />
      <RowDefinition Height="*" />
      <RowDefinition Height="18" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="18" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="18" />
    </Grid.ColumnDefinitions>

    <primitives:Thumb Grid.Row="0" Grid.Column="0" Cursor="SizeNWSE" Style="{StaticResource ResizeThumbStyle}" Tag="TopLeft" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
    <primitives:Thumb Grid.Row="0" Grid.Column="1" Cursor="SizeNS" Style="{StaticResource ResizeThumbStyle}" Tag="Top" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
    <primitives:Thumb Grid.Row="0" Grid.Column="2" Cursor="SizeNESW" Style="{StaticResource ResizeThumbStyle}" Tag="TopRight" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
    <primitives:Thumb Grid.Row="1" Grid.Column="0" Cursor="SizeWE" Style="{StaticResource ResizeThumbStyle}" Tag="Left" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
    <primitives:Thumb Grid.Row="1" Grid.Column="1" Cursor="SizeAll" Style="{StaticResource ResizeThumbStyle}" Tag="Move" DragStarted="MoveThumb_OnDragStarted" DragDelta="MoveThumb_OnDragDelta" DragCompleted="MoveThumb_OnDragCompleted" />
    <primitives:Thumb Grid.Row="1" Grid.Column="2" Cursor="SizeWE" Style="{StaticResource ResizeThumbStyle}" Tag="Right" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
    <primitives:Thumb Grid.Row="2" Grid.Column="0" Cursor="SizeNESW" Style="{StaticResource ResizeThumbStyle}" Tag="BottomLeft" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
    <primitives:Thumb Grid.Row="2" Grid.Column="1" Cursor="SizeNS" Style="{StaticResource ResizeThumbStyle}" Tag="Bottom" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
    <primitives:Thumb Grid.Row="2" Grid.Column="2" Cursor="SizeNWSE" Style="{StaticResource ResizeThumbStyle}" Tag="BottomRight" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
  </Grid>
</Window>
