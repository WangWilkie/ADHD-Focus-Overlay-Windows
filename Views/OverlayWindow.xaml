<Window x:Class="AdhdFocusOverlay.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        WindowStyle="None">
  <Grid Background="Transparent" MouseLeftButtonDown="RootGrid_MouseLeftButtonDown">
    <Canvas x:Name="LightweightMaskCanvas"
            IsHitTestVisible="False"
            Visibility="Collapsed">
      <Rectangle x:Name="TopMask" SnapsToDevicePixels="True" />
      <Rectangle x:Name="LeftMask" SnapsToDevicePixels="True" />
      <Rectangle x:Name="RightMask" SnapsToDevicePixels="True" />
      <Rectangle x:Name="BottomMask" SnapsToDevicePixels="True" />
    </Canvas>
    <Path x:Name="MaskPath"
          RenderOptions.EdgeMode="Aliased"
          SnapsToDevicePixels="True"
          Stretch="None" />
    <Border x:Name="PickModeBadge"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="18,10"
            Background="#CC111111"
            BorderBrush="#66FFFFFF"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
      <StackPanel>
        <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Pick Monitor" />
        <TextBlock x:Name="PickModeText"
                   Margin="0,4,0,0"
                   Foreground="#DDFFFFFF"
                   Text="Click this monitor to move the focus box here." />
      </StackPanel>
    </Border>
  </Grid>
</Window>
